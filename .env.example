DJANGO_SECRET_KEY=django-insecure-local-development-key
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Local uv run uses SQLite by default. Docker Compose overrides this to postgresql.
DATABASE_ENGINE=sqlite

# Used by Docker Compose for the PostgreSQL container.
POSTGRES_DB=cash_flow_manager
POSTGRES_USER=cash_flow_user
POSTGRES_PASSWORD=cash_flow_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
